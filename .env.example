# Application
APP_ENV=development

# Database (used by the db service and assembled into DATABASE_URL for the API)
POSTGRES_DB=opsdeck
POSTGRES_USER=opsdeck
POSTGRES_PASSWORD=opsdeck

# For local (non-Docker) backend runs, point the API at a database directly.
# Docker Compose builds this value from the POSTGRES_* variables above.
# DATABASE_URL=postgresql+psycopg://opsdeck:opsdeck@localhost:5432/opsdeck
# DATABASE_URL=sqlite:///./opsdeck.db

# API
CORS_ORIGINS=http://localhost:3000

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Host port mappings (optional overrides)
API_PORT=8000
WEB_PORT=3000
DB_PORT=5432
